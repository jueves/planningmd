ACCESS_TOKEN=your-secret-access-token

TODOIST_API_TOKEN=here-the-token
TODOIST_FILTER="!#Home & today"
SUBTASK_DAYS=7

# iCal / CalDAV calendars
ICAL_SERVER_URL=https://caldav.example.com
ICAL_USERNAME=your-username
ICAL_PASSWORD=your-password
# Comma-separated display names of calendars to include (leave empty for all)
ICAL_CALENDAR_NAMES=Work,Personal
# Number of days ahead to include (starting from today)
ICAL_DAYS_AHEAD=7
