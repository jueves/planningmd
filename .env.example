TODOIST_API_TOKEN=here-the-token
TODOIST_FILTER="!#Home & today"
SUBTASK_DAYS=7

# iCal calendars
ICAL_USERNAME=your-username
ICAL_PASSWORD=your-password
# Comma-separated list of .ics URLs
ICAL_URLS=https://example.com/calendar1.ics,https://example.com/calendar2.ics
# Number of days ahead to include (starting from today)
ICAL_DAYS_AHEAD=7
